   "source": [
    "# Fine-tune NLLB-200 на ингушском языке\n",
    "\n",
    "**Перед запуском:** Runtime → Change runtime type → **T4 GPU**\n",
    "\n",
    "Затем: Runtime → **Run all** (Ctrl+F9) и уходи по делам.\n",
    "\n",
    "Модель сохранится на Google Drive в папке `My Drive/nllb-ingush/`."
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Проверяем GPU\n",
    "import torch\n",
    "print(\"GPU:\", torch.cuda.get_device_name(0) if torch.cuda.is_available() else \"НЕТ GPU — смени runtime!\")\n",
    "assert torch.cuda.is_available(), \"Нужен GPU!\""
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Устанавливаем зависимости\n",
    "!pip install -q transformers[torch] datasets sacrebleu sentencepiece evaluate accelerate"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Клонируем репо с данными и кодом\n",
    "!git clone https://github.com/Morgxth/GhalghayTools.git\n",
    "%cd GhalghayTools/corpus/finetune\n",
    "!echo \"Train строк:\" $(wc -l < train.jsonl)\n",
    "!echo \"Dev строк:\"   $(wc -l < dev.jsonl)"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Монтируем Google Drive для сохранения модели\n",
    "from google.colab import drive\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "import os\n",
    "SAVE_DIR = \"/content/drive/MyDrive/nllb-ingush\"\n",
    "os.makedirs(SAVE_DIR, exist_ok=True)\n",
    "print(f\"Модель будет сохранена в: {SAVE_DIR}\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Запускаем обучение\n",
    "# 88K примеров, batch 8 × grad_acc 4 = eff batch 32\n",
    "# ~2750 шагов/эпоха × 3 эпохи ≈ 3-4 часа на T4\n",
    "!python train.py \\\n",
    "    --train  train.jsonl \\\n",
    "    --dev    dev.jsonl \\\n",
    "    --epochs 3 \\\n",
    "    --batch  8 \\\n",
    "    --grad-acc 4 \\\n",
    "    --lr     5e-5 \\\n",
    "    --max-len 128 \\\n",
    "    --out    {SAVE_DIR}"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Тест перевода после обучения\n",
    "from transformers import pipeline\n",
    "\n",
    "pipe_inh2rus = pipeline(\n",
    "    \"translation\",\n",
    "    model=SAVE_DIR,\n",
    "    src_lang=\"inh_Cyrl\",\n",
    "    tgt_lang=\"rus_Cyrl\",\n",
    "    max_length=256,\n",
    "    device=0,\n",
    ")\n",
    "\n",
    "pipe_rus2inh = pipeline(\n",
    "    \"translation\",\n",
    "    model=SAVE_DIR,\n",
    "    src_lang=\"rus_Cyrl\",\n",
    "    tgt_lang=\"inh_Cyrl\",\n",
    "    max_length=256,\n",
    "    device=0,\n",
    ")\n",
    "\n",
    "test_sentences = [\n",
    "    (\"inh→rus\", pipe_inh2rus, \"Даьла безам бе, хьо сона везаш ва.\"),\n",
    "    (\"inh→rus\", pipe_inh2rus, \"Ингушетийн Республика Россе юкъе ю.\"),\n",
    "    (\"inh→rus\", pipe_inh2rus, \"Тахан маьрша де ду.\"),\n",
    "    (\"rus→inh\", pipe_rus2inh, \"Сегодня хорошая погода.\"),\n",
    "    (\"rus→inh\", pipe_rus2inh, \"Республика Ингушетия входит в состав России.\"),\n",
    "]\n",
    "\n",
    "print(\"=== Примеры переводов ===\")\n",
    "for direction, pipe, text in test_sentences:\n",
    "    result = pipe(text)[0][\"translation_text\"]\n",
    "    print(f\"\\n[{direction}]\")\n",
    "    print(f\"  Вход:  {text}\")\n",
    "    print(f\"  Выход: {result}\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Оценка BLEU на тестовой выборке\n",
    "import json\n",
    "import evaluate\n",
    "\n",
    "bleu = evaluate.load(\"sacrebleu\")\n",
    "\n",
    "test_rows = [json.loads(l) for l in open(\"test.jsonl\") if l.strip()]\n",
    "inh2rus_test = [r for r in test_rows if r[\"src_lang\"] == \"inh_Cyrl\"][:500]\n",
    "\n",
    "print(f\"Тестируем на {len(inh2rus_test)} примерах inh→rus...\")\n",
    "preds = [pipe_inh2rus(r[\"src\"])[0][\"translation_text\"] for r in inh2rus_test]\n",
    "refs  = [[r[\"tgt\"]] for r in inh2rus_test]\n",
    "\n",
    "score = bleu.compute(predictions=preds, references=refs)\n",
    "print(f\"BLEU (inh→rus, test): {score['score']:.2f}\")"
   ],
   "execution_count": null,
   "outputs": []
  }
 ]
}"
